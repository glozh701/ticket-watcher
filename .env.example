# Ticket watcher configuration
# Copy this to .env and fill in your values

# What to watch
PRODUCT_ID=452
SESSION_CODE=ELS08

# Email notifications (Gmail example — use an App Password, not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
NOTIFY_TO=your-email@gmail.com
NOTIFY_FROM=your-email@gmail.com

# Optional overrides
# STATE_FILE=last_status.json
# MAX_RETRIES=3
# RETRY_DELAY=5
